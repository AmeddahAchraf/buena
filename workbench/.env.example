# ─────────────────────────────────────────────────────────────────────────────
# Property Context Workbench — environment configuration
#
# Copy this file to .env.local and fill in the values you need.
#   cp .env.example .env.local
#
# .env.local is git-ignored. Never commit real API keys.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI provider selection ────────────────────────────────────────────────────
# When GEMINI_API_KEY is set, getAI() prefers Gemini automatically.
# Set AI_PROVIDER=xai to force xAI even when both keys are present.
# Leave unset to use the default selection logic.
AI_PROVIDER=

# ── Gemini (Google AI Studio) — OpenAI-compatible endpoint ───────────────────
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# ── xAI (optional fallback) ──────────────────────────────────────────────────
# Get a key at https://console.x.ai/
XAI_API_KEY=
XAI_MODEL=grok-4-fast-reasoning
XAI_BASE_URL=https://api.x.ai/v1

# ── Gradium (voice search — Speech-to-Text) ──────────────────────────────────
# Optional. When set, the search field shows a mic button that streams audio
# to Gradium's STT WebSocket and pastes the transcript into the search input.
# Get a key at https://studio.gradium.ai/
GRADIUM_API_KEY=

# ── Paths (defaults assume the dataset sits one level above workbench/) ──────
DATASET_ROOT=../
OUT_ROOT=../out
CACHE_ROOT=../.workbench-cache
